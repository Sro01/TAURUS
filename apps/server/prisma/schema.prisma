// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------
// Enums
// --------------------------------------

enum Role {
  USER
  ADMIN
}

enum WeekStatus {
  OPEN     // 바로 예약 가능 (현재 주차)
  CLOSED   // 예약 마감 (과거 주차)
  UPCOMING // 미리 예약 기간 (다음 주차)
}

enum ReservationStatus {
  PENDING          // 예약 대기 (미리 예약)
  CONFIRMED        // 예약 확정
  CONFIRMED_ADMIN  // 관리자 우선 예약 — 선택 불가 표시
  VOID             // 예약 취소/폭파 (시스템)
  CANCELLED        // 예약 취소 (사용자)
}

enum ReservationType {
  INSTANT // 바로 예약
  PRE     // 미리 예약
  ADMIN   // 관리자 우선 예약
}

// --------------------------------------
// Models
// --------------------------------------

model Team {
  id          String   @id @default(uuid())
  name        String   @unique // 팀명 (로그인 ID 역할)
  password    String   // 해시된 비밀번호
  role        Role     @default(USER)
  tokenVersion Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz 
  updatedAt   DateTime @updatedAt @db.Timestamptz

  reservations Reservation[]

  @@map("teams")
}

model Week {
  id         Int        @id @default(autoincrement())
  startDate  DateTime   @unique @db.Timestamptz // 일요일 00:00:00 KST
  endDate    DateTime   @db.Timestamptz // 토요일 23:59:59 KST
  status     WeekStatus @default(UPCOMING)
  year       Int        // 연도
  weekNumber Int        // 연도 내 주차 번호 (1~52)

  reservations Reservation[]

  @@unique([year, weekNumber]) // 같은 연도에 같은 weekNumber 중복 방지

  @@index([status])  // OPEN/UPCOMING 조회
  @@index([year])    // 연도별 조회
  @@map("weeks")
}

model Reservation {
  id        String            @id @default(uuid())
  startTime DateTime          @db.Timestamptz // 슬롯 시작 시간
  endTime   DateTime          @db.Timestamptz // 슬롯 종료 시간 (시작 + 50분)
  status    ReservationStatus @default(PENDING)
  type      ReservationType   @default(INSTANT)
  description String?           // 관리자 예약 등의 메모 (nullable)

  teamId String?  // 관리자 예약은 teamId 없음 (시스템 예약)
  team   Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  weekId Int
  week   Week @relation(fields: [weekId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([startTime])
  @@index([teamId])
  @@index([weekId])
  @@map("reservations")
}

model SystemConfig {
  key   String @id
  value String

  @@map("system_configs")
}
